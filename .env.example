# ─────────────────────────────────────────────────────────────
# AI Trading Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Binance API ──────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use testnet? (true = paper trading, false = real money)
USE_TESTNET=true

# ── Trading ──────────────────────────────────────────────────
TRADING_SYMBOL=BTCUSDT
TIMEFRAME=1h
LOOKBACK_PERIODS=100

# ── Strategies (comma-separated) ────────────────────────────
ENABLED_STRATEGIES=trend,mean_reversion,momentum

# ── Risk Management ─────────────────────────────────────────
RISK_PER_TRADE=0.02
MAX_POSITION_PCT=0.10
MAX_DAILY_LOSS=0.05
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.06
TRADE_COOLDOWN_SECONDS=300

# ── ML Model (optional) ─────────────────────────────────────
USE_ML_MODEL=false
ML_MODEL_PATH=

# ── Bot Settings ─────────────────────────────────────────────
LOOP_INTERVAL_SECONDS=60
DB_PATH=data/market_cache.db
LOG_LEVEL=INFO
